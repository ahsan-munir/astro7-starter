{
  "name": "ambi-astro-starter",
  "type": "module",
  "version": "1.0.0",
  "description": "AMBI Astro starter — locked dev architecture + SEO standard baked in. New site = use this template.",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cms:switch": "node scripts/switch-cms.mjs",
    "prebuild": "node scripts/switch-cms.mjs",
    "check": "astro check",
    "format": "prettier --write \"**/*.{astro,ts,js,mjs,md,mdx,json,css}\"",
    "lint": "eslint . --ext .js,.mjs,.ts,.astro"
  },
  "dependencies": {
    "astro": "^7.0.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "eslint": "^10.5.0",
    "@eslint/js": "^10.0.1",
    "eslint-plugin-astro": "^2.1.0",
    "typescript-eslint": "^8.62.0"
  }
}
