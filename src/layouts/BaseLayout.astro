---
/**
 * BaseLayout — the page shell every route uses. (dev-architecture §4)
 * Renders <head> SEO, global styles, site-wide Organization schema, fonts
 * (preloaded + display:swap, seo-standard §3), header, <slot/>, footer.
 */
import "@styles/global.css";
import SEO from "@components/seo/SEO.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import { siteConfig } from "@lib/site";
import { organizationSchema } from "@lib/schema";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  bareTitle?: boolean;
  /** Extra page-level schema (BlogPosting, FAQPage, Person, …). */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { schema, ...seo } = Astro.props;
const orgSchema = organizationSchema(Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    {/* Fonts — preconnect + display:swap (seo-standard §3) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />

    <SEO {...seo} />
    <JsonLd schema={orgSchema} />
    {schema && <JsonLd schema={schema} />}
  </head>

  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-contrast"
    >
      Skip to content
    </a>

    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
