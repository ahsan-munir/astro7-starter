---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/ui/Button.astro";
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist." noindex>
  <section class="section-pad">
    <div class="container-page mx-auto max-w-xl text-center">
      <p class="font-heading text-6xl font-bold text-primary">404</p>
      <h1 class="mt-4 text-3xl font-bold">This page wandered off.</h1>
      <p class="mt-4 text-body">
        The page you're looking for doesn't exist or has moved.
      </p>
      <div class="mt-8">
        <Button href="/">Back to home</Button>
      </div>
    </div>
  </section>
</BaseLayout>
