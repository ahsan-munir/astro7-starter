---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import { blogPostingSchema, breadcrumbSchema } from "@lib/schema";

export const getStaticPaths = (async () => {
  const posts = await getCollection("blog", ({ data }) => import.meta.env.DEV || !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await render(post);
const site = Astro.site ?? Astro.url.origin;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const schema = [
  blogPostingSchema(
    {
      title: post.data.title,
      description: post.data.description,
      slug: post.id,
      pubDate: post.data.pubDate,
      updatedDate: post.data.updatedDate,
      author: post.data.author,
      image: post.data.seo?.ogImage,
    },
    site,
  ),
  breadcrumbSchema(
    [
      { name: "Home", href: "/" },
      { name: "Blog", href: "/blog" },
      { name: post.data.title, href: `/blog/${post.id}` },
    ],
    site,
  ),
];
---

<BaseLayout
  title={post.data.seo?.title ?? post.data.title}
  description={post.data.seo?.description ?? post.data.description}
  ogType="article"
  ogImage={post.data.seo?.ogImage}
  noindex={post.data.seo?.noindex}
  schema={schema}
>
  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Blog", href: "/blog" },
      { name: post.data.title, href: `/blog/${post.id}` },
    ]}
  />

  <article class="section-pad">
    <div class="container-page mx-auto max-w-2xl">
      <header>
        <time datetime={post.data.pubDate.toISOString()} class="text-sm text-muted">
          {fmt(post.data.pubDate)}
        </time>
        <h1 class="mt-2 text-4xl font-bold tracking-tight">{post.data.title}</h1>
        <p class="mt-4 text-lg text-body">{post.data.description}</p>
      </header>

      {
        post.data.cover && (
          <Image
            src={post.data.cover}
            alt={post.data.coverAlt}
            widths={[480, 768, 1024]}
            sizes="(max-width: 768px) 100vw, 672px"
            class="mt-8 rounded-lg shadow-md"
          />
        )
      }

      <div
        class="prose mt-10 max-w-none [&_a]:text-primary [&_a]:underline [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_li]:mt-1 [&_p]:mt-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-6"
      >
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
