---
/** Breadcrumbs — inner pages; also feeds BreadcrumbList schema. (seo-standard §4) */
interface Props {
  items: { name: string; href: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="container-page pt-8">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-muted">
    {
      items.map((item, i) => (
        <li class="flex items-center gap-2">
          {i < items.length - 1 ? (
            <a href={item.href} class="hover:text-primary">
              {item.name}
            </a>
          ) : (
            <span class="text-heading" aria-current="page">
              {item.name}
            </span>
          )}
          {i < items.length - 1 && <span aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
