---
import { siteConfig } from "@lib/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/90 backdrop-blur">
  <nav
    class="container-page flex h-16 items-center justify-between"
    aria-label="Primary"
  >
    <a href="/" class="font-heading text-lg font-bold text-heading">
      {siteConfig.name}
    </a>

    <ul class="flex items-center gap-6 text-sm font-medium">
      {
        siteConfig.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                "transition-colors hover:text-primary",
                isActive(item.href) ? "text-primary" : "text-body",
              ]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
