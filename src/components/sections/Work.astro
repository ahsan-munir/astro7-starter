---
/** WORK — prove outcomes, not just visuals. (gallery WORK.01) */
import Section from "@components/ui/Section.astro";

interface Props {
  intro: string;
  cases: { client: string; result: string; href?: string }[]; // 2–3
}
const { intro, cases } = Astro.props;
---

<Section surface="muted">
  <div class="mx-auto max-w-2xl text-center">
    <p class="text-lg text-body">{intro}</p>
  </div>
  <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      cases.map((c) => (
        <article class="rounded-lg border border-border bg-surface p-6 shadow-sm">
          <h3 class="font-semibold text-heading">{c.client}</h3>
          <p class="mt-2 text-sm text-body">{c.result}</p>
          {c.href && (
            <a
              href={c.href}
              class="mt-4 inline-block text-sm font-medium text-primary"
            >
              View case study &rarr;
            </a>
          )}
        </article>
      ))
    }
  </div>
</Section>
