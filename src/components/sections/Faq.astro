---
/**
 * FAQ — kill the last objections. (gallery FAQ.01)
 * Uses native <details> → accordion with ZERO JS (dev-architecture §6 default).
 * Emits FAQPage schema (seo-standard §2).
 */
import Section from "@components/ui/Section.astro";
import JsonLd from "@components/seo/JsonLd.astro";
import { faqSchema } from "@lib/schema";

interface Props {
  headline?: string;
  items: { q: string; a: string }[]; // 3–6
  emitSchema?: boolean;
}
const { headline = "Frequently asked questions", items, emitSchema = true } = Astro.props;
const schema = emitSchema ? faqSchema(items) : null;
---

<Section id="faq">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center text-3xl font-bold">{headline}</h2>
    <div class="mt-10 divide-y divide-border border-y border-border">
      {
        items.map((item) => (
          <details class="group py-4">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-heading marker:content-['']">
              {item.q}
              <span
                class="ml-4 flex-none text-primary transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 text-sm text-body">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</Section>

{schema && <JsonLd schema={schema} />}
